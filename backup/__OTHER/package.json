                   "https://github.com/fccview/degoog"
                ],
                "Retrieved": "2026-03-24"
            },
            "Content": [
                "services:",
                "  degoog:",
                "    image: ghcr.io/fccview/degoog:latest",
                "    volumes:",
                "      - ./data:/app/data",
                "    user: \"1000:1000\"",
                "    ports:",
                "      - \"4444:4444\"",
                "    restart: unless-stopped"
            ]
