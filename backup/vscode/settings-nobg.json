{
    // (karlr 2025-12-16)
    "github.copilot.chat.agent.enabled": false,
    "github.copilot.chat.experimental.agent.enabled": false,
    "chat.disableAIFeatures": true,

    "markdown-preview-enhanced.revealjsTheme": "night.css",
    "markdown-preview-enhanced.previewTheme": "github-dark.css",
    "markdown.extension.toc.slugifyMode": "vscode",
    "markdown.extension.toc.updateOnSave": true,
    "markdown.extension.completion.enabled": false,
    "markdown.extension.list.indentationSize": "adaptive",
    "markdown.extension.list.continuation": false,
    "workbench.editorAssociations": {
        "*.ipynb": "jupyter-notebook"
    },
    "kite.showWelcomeNotificationOnStartup": false,
    "editor.suggestSelection": "first",
    "vsintellicode.modify.editor.suggestSelection": "automaticallyOverrodeDefaultValue",
    "files.exclude": {
        "**/.classpath": true,
        "**/.project": true,
        "**/.settings": true,
        "**/.factorypath": true
    },
    "maven.executable.path": "${env:ProgramData}\\chocolatey\\lib\\maven\\apache-maven-3.8.1\\bin\\mvn.cmd",
    "java.project.importOnFirstTimeStartup": "automatic",
    "testMate.cpp.log.userId": "2d84b0e6b542af89df067031a2ac8f4377d42567",
    "testMate.cpp.log.logSentry": "enable",
    "explorer.confirmDelete": false,
    "editor.lineNumbers": "relative",
    "[markdown]": {
        "editor.suggest.enabled": false
    },
    "[python]": {
        // link: Visual Studio Code - Vertical rulers #vscode
        // - url: <https://www.youtube.com/watch?v=HPKBkJPs2DM>
        // - retrieved: 2025-01-11
        "editor.rulers": [
            { "column": 79, "color": "#a400dbF0" },
            { "column": 72, "color": "#005dcff0" }
        ],

        "editor.formatOnType": false,
        "editor.acceptSuggestionOnCommitCharacter": false,
        "editor.autoSurround": "never",
        "editor.autoClosingBrackets": "never",
        "editor.autoClosingDelete": "never",
        "editor.autoClosingComments": "never",
        "editor.autoClosingOvertype": "never",
        "editor.autoClosingQuotes": "never"
    },
    "[go]": {
        "editor.formatOnType": true,
        "editor.rulers": [
            { "column": 79, "color": "#a400dbF0" },
            { "column": 72, "color": "#005dcff0" }
        ]
    },
    "git.autofetch": true,
    "vim.enableNeovim": true,
    "vim.neovimConfigPath": "~/AppData/Local/nvim/init.lua",
    "vim.neovimPath": "${env:SystemDrive}/tools/neovim/nvim-win64/bin/nvim.exe",
    "vim.neovimUseConfigFile": true,
    "background.style": {
        "content": "''",
        "pointer-events": "none",
        "position": "absolute",
        "z-index": "99999",
        "width": "100%",
        "height": "100%",
        "background-position": "100% 100%",
        "background-repeat": "no-repeat",
        "opacity": 0.4
    },
    "background.autoInstall": false,
    "background.editorBackgrounds": [
    ],
    "background.windowBackgrounds": [
    ],
    "background.backgroundOpacity": [
        0.94,
        0.65,
        0.9,
        0.9,
    ],
    "editor.fontLigatures": true,
    "editor.fontFamily": "\"Fira Code\", monospace",
    "terminal.integrated.fontFamily": "\"Fira Code\", monospace",
    "git.openRepositoryInParentFolders": "always",
    "terminal.integrated.defaultProfile.windows": "PowerShell",
    "cmake.configureOnOpen": true,
    "security.workspace.trust.untrustedFiles": "open",
    "security.workspace.trust.banner": "never",
    "security.workspace.trust.startupPrompt": "never",
    "security.workspace.trust.enabled": false,
    "workbench.colorTheme": "Aura Dracula Spirit (Synthwave)",
    "extensions.experimental.affinity": {
        "asvetliakov.vscode-neovim": 1
    },
    "workbench.editor.enablePreviewFromQuickOpen": true,
    "background.useInvertedOpacity": true,
    "workbench.iconTheme": "material-icon-theme",
    "redhat.telemetry.enabled": true,
    "glassit.alpha": 250,
    "dart.flutterSdkPath": "${env:SystemDrive}\\tools\\flutter",
    "cmake.options.statusBarVisibility": "icon",
    "cmake.pinnedCommands": [
        "workbench.action.tasks.configureTaskRunner",
        "workbench.action.tasks.runTask"
    ],
    "editor.autoClosingBrackets": "never",
    "python.defaultInterpreterPath": "${env:SystemDrive}\\Python312\\python.exe",
    "python.analysis.typeCheckingMode": "basic",
    "python.createEnvironment.trigger": "off",
    "python.autoComplete.addBrackets": false,
    "editor.autoSurround": "never",
    "editor.acceptSuggestionOnCommitCharacter": false,
    "editor.autoClosingQuotes": "never"
}
